<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="2dp"
    android:background="@color/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerInParent="true"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textColor="@color/widget_accent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/prayer_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="@color/widget_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <Chronometer
            android:id="@+id/prayer_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/prayer_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="0dp" />

        <LinearLayout
            android:id="@+id/secondary_prayer_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/secondary_prayer_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/widget_text_tertiary"
                android:textSize="12sp" />

            <Chronometer
                android:id="@+id/secondary_prayer_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_tertiary"
                android:textSize="12sp"
                android:layout_marginStart="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/secondary_prayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/widget_text_tertiary"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="0dp" />

    </LinearLayout>

</RelativeLayout>
